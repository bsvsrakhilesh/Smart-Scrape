datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum SourceKind {
  URL
  FILE
}

enum TaggingStatus {
  NONE
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum CaptureType {
  UPLOAD
  URL_TEXT
  URL_PDF
}

model Url {
  id            Int      @id @default(autoincrement())
  url           String   @unique
  title         String
  snippet       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isFavorited   Boolean  @default(false)
  notes         String?
  tags          String[] @default([])
  contentHash   String?
  taggerVersion String?
  tagsMeta      Json?

  taggingStatus TaggingStatus @default(NONE)
  taggingJobId  String?
  taggingError  String?

  snapshots StoredFile[] @relation("UrlSnapshots")

  notebookSources NotebookSource[] @relation("UrlNotebookSources")
}

model StoredFile {
  id             String    @id
  fileName       String
  mimeType       String
  size           Int
  description    String?
  uploaderName   String
  uploaderId     String?
  tags           String[]  @default([])
  visibility     String    @default("private")
  downloads      Int       @default(0)
  favoritesCount Int       @default(0)
  isFavorited    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  storagePath    String // absolute path to file on disk
  folderId       String?
  folder         Folder?   @relation(fields: [folderId], references: [id])
  contentHash    String?

  captureType  CaptureType @default(UPLOAD)
  sha256       String?
  sourceUrl    String?

  urlId Int?
  url   Url? @relation("UrlSnapshots", fields: [urlId], references: [id], onDelete: SetNull)

  taggerVersion  String?
  tagsMeta       Json?

  notebookSources NotebookSource[] @relation("FileNotebookSources")

  @@index([urlId])
  @@index([deletedAt])
  
}

model Folder {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?      @relation("FolderToFolder", fields: [parentId], references: [id])
  children  Folder[]     @relation("FolderToFolder")
  files     StoredFile[]
  createdAt DateTime     @default(now())
  deletedAt DateTime?

  @@index([deletedAt])
}

model Notebook {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources NotebookSource[]
  notes   Note[]
}

model NotebookSource {
  id         String     @id @default(cuid())
  notebook   Notebook   @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  notebookId String
  kind       SourceKind

  url   Url? @relation("UrlNotebookSources", fields: [urlId], references: [id])
  urlId Int?

  file   StoredFile? @relation("FileNotebookSources", fields: [fileId], references: [id])
  fileId String?

  chunks       SourceChunk[]
  embeddingJob EmbeddingJob?
  pages        SourcePage[]
  ingestionJob IngestionJob?
  createdAt    DateTime      @default(now())

  activeRevisionId String?
  activeRevision   SourceRevision? @relation("ActiveRevision", fields: [activeRevisionId], references: [id])

  @@unique([notebookId, urlId])
  @@unique([notebookId, fileId])
}

model SourceRevision {
  id         String         @id @default(cuid())
  source     NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId   String
  ordinal    Int
  contentHash String?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())

  chunks SourceChunk[]
  pages  SourcePage[]

  @@unique([sourceId, ordinal])
  @@index([sourceId, isActive])
}

model SourceChunk {
  id       String         @id @default(cuid())
  source   NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId String
  revision   SourceRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String
  idx      Int
  text     String
  tokens   Int

  embedding      Unsupported("vector(1536)")?
  embeddingModel String?
  embeddedAt     DateTime?
  fts            Unsupported("tsvector")?
  globalStart    Int?
  globalEnd      Int?

  pageStart Int?
  pageEnd   Int?
  charStart Int?
  charEnd   Int?

  createdAt DateTime @default(now())

  @@unique([revisionId, idx])
  @@index([sourceId, revisionId])

}

model EmbeddingJob {
  id       String         @id @default(cuid())
  source   NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId String         @unique

  status       TaggingStatus @default(PENDING)
  attemptCount Int           @default(0)
  error        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngestionJob {
  id       String         @id @default(cuid())
  source   NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId String         @unique

  status       TaggingStatus @default(PENDING)
  attemptCount Int           @default(0)
  error        String?
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
}

model SourcePage {
  id         String         @id @default(cuid())
  source     NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId   String
  pageNumber Int
  text       String

  // global offsets into the concatenated fullText (including page separators)
  globalStart Int
  globalEnd   Int

  createdAt DateTime @default(now())

  revision   SourceRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String

  @@unique([revisionId, pageNumber])
  @@index([sourceId, revisionId])
  @@index([sourceId])
}

model Note {
  id         String   @id @default(cuid())
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  notebookId String
  title      String?
  content    String
  citations  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
