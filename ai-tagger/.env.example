# Broker & cache
REDIS_URL=
PORT=
# Optional OCR.
# PDFs use native extraction first, then OCRmyPDF, then Tesseract fallback.
OCR_ENABLED=
OCR_ENGINE=
OCR_DESKEW=
OCR_ROTATE_PAGES=
OCR_CLEAN=
OCR_FALLBACK=
OCR_TIMEOUT_SECONDS=
AI_TAGGER_WORKER_CONCURRENCY=2

# Version label (returns in API; helpful for audits)
TAGGER_VERSION=

# LLM enhancement for tag ranking plus structured/governance extraction.
# Set OPENAI_API_KEY and keep STRUCTURED_LLM_ENABLED=true for the strongest tagging path.
OPENAI_API_KEY=
LLM_MODEL=

STRUCTURED_LLM_ENABLED=true
STRUCTURED_LLM_MODEL=
STRUCTURED_LLM_TIMEOUT_S=
STRUCTURED_LLM_MAX_CHARS=
STRUCTURED_LLM_MAX_UNITS=

OCR_LANGS=
OCR_PDF_DPI=
OCR_MAX_PAGES=
OCR_PDF_MIN_CHARS=
OCR_IMAGE_MAX_SIDE=
OCR_IMAGE_MIN_CHARS=
OCR_WEAK_PAGE_CHARS=
