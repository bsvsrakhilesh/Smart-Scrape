datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum SourceKind {
  URL
  FILE
}

enum TaggingStatus {
  NONE
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum CaptureType {
  UPLOAD
  URL_TEXT
  URL_PDF
}

enum CaptureScope {
  SOURCE_PAGE
  DISCOVERED_DOCUMENT
}

enum DocumentKind {
  URL
  FILE
}

enum NotebookChatRunStatus {
  STARTED
  SUCCEEDED
  FAILED
}

enum AuditResourceType {
  DOCUMENT
  FILE
  URL
  NOTEBOOK
  NOTE
  NOTEBOOK_SOURCE
  ISSUE
  AGENCY
  CHAT_RUN
  SYSTEM
}

enum AuditLogStatus {
  SUCCESS
  FAILURE
  INFO
}

enum AgencyCategory {
  REGULATOR
  JUDICIARY
  MINISTRY
  EXECUTIVE
  LOCAL_BODY
  RESEARCH_BODY
  CIVIL_SOCIETY
  PRIVATE_SECTOR
  OTHER
}

enum GovernanceIssueKind {
  GOVERNANCE_ISSUE
  CASE_FILE
}

enum GovernanceIssueStatus {
  OPEN
  MONITORING
  RESOLVED
  CLOSED
  ARCHIVED
}

enum MandateType {
  STATUTORY
  REGULATORY
  ADVISORY
  ENFORCEMENT
  OPERATIONAL
  COORDINATION
  REPORTING
  MONITORING
  OTHER
}

enum PositionPolarity {
  SUPPORT
  OPPOSE
  NEUTRAL
  MIXED
  UNKNOWN
}

enum GovernanceGapType {
  OVERLAP
  AMBIGUITY
  ACCOUNTABILITY
  COORDINATION
  ENFORCEMENT
  DATA
  EVIDENCE
  COVERAGE
  OTHER
}

enum DocumentRelationType {
  CONTRADICTION
  TENSION
  OVERRIDE
  REINFORCEMENT
  ALIGNMENT
  DUPLICATION
  REFERENCE
  SUPERSEDES
  OTHER
}

enum EventDatePrecision {
  EXACT
  DAY
  MONTH
  YEAR
  RANGE
  APPROXIMATE
  UNKNOWN
}

model Url {
  id               Int      @id @default(autoincrement())
  url              String
  canonical_url    String?  @unique
  normalizedDomain String?
  title            String
  snippet          String?
  publishedAt      DateTime?
  authors          String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastVisitedAt    DateTime?
  visitCount       Int      @default(0)
  isFavorited      Boolean  @default(false)
  notes            String?
  tags             String[] @default([])
  visibility       String   @default("private")
  contentHash      String?
  taggerVersion    String?
  tagsMeta         Json?

  document Document?

  taggingStatus TaggingStatus @default(NONE)
  taggingJobId  String?
  taggingError  String?

  snapshots StoredFile[] @relation("UrlSnapshots")
  discoveryRuns UrlDiscoveryRun[] @relation("UrlDiscoveryRuns")
  discoveredDocuments UrlDiscoveredDocument[] @relation("UrlDiscoveredDocuments")

  notebookSources NotebookSource[] @relation("UrlNotebookSources")
  captureEvents   CaptureEvent[]
  collections     CollectionUrl[]
  reviews         SavedUrlReview[]
  collectorPurposeLinks CollectorPurposeUrl[]

  @@index([createdAt])
  @@index([updatedAt])
  @@index([publishedAt])
  @@index([isFavorited])
  @@index([visibility])
  @@index([taggingStatus])
  @@index([normalizedDomain])
  @@index([normalizedDomain, createdAt])
  @@index([taggingStatus, updatedAt])
  @@index([isFavorited, updatedAt])
}

model CollectorPurpose {
  id                String   @id @default(cuid())
  ownerId           String
  title             String
  researchQuestion  String
  jurisdiction      String?
  region            String?
  yearFrom          String?
  yearTo            String?
  sourcePreferences String[] @default([])
  targetActors      String[] @default([])
  outputGoal        String?
  status            String   @default("active")
  plan              Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  searches       CollectorPurposeSearch[]
  urls           CollectorPurposeUrl[]
  answerSessions GovernanceAnswerSession[]
  answerRuns     GovernanceAnswerRun[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, status])
}

model CollectorPurposeSearch {
  id          String   @id @default(cuid())
  purposeId   String
  purpose     CollectorPurpose @relation(fields: [purposeId], references: [id], onDelete: Cascade)
  query       String
  laneKey     String?
  parameters  Json?
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  linkedUrls CollectorPurposeUrl[] @relation("CollectorPurposeSourceSearch")

  @@index([purposeId, createdAt])
}

model CollectorPurposeUrl {
  purposeId      String
  urlId          Int
  sourceSearchId String?
  linkedAt       DateTime @default(now())
  purpose        CollectorPurpose @relation(fields: [purposeId], references: [id], onDelete: Cascade)
  url            Url @relation(fields: [urlId], references: [id], onDelete: Cascade)
  sourceSearch   CollectorPurposeSearch? @relation("CollectorPurposeSourceSearch", fields: [sourceSearchId], references: [id], onDelete: SetNull)

  @@id([purposeId, urlId])
  @@index([urlId])
  @@index([sourceSearchId])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String?  // optional until auth exists
  visibility  String   @default("private")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  urls                CollectionUrl[]
  savedSearchPresets  SavedUrlSearchPreset[]
}

model SavedUrlSearchPreset {
  id                   String   @id @default(cuid())
  ownerId              String
  name                 String
  filter               Json
  sortKey              String
  sortOrder            String
  year                 String
  selectedCollectionId String?
  queueId              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  selectedCollection Collection? @relation(fields: [selectedCollectionId], references: [id], onDelete: SetNull)

  @@unique([ownerId, name])
  @@index([ownerId, updatedAt])
}

model CollectionUrl {
  collectionId String
  urlId        Int
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  url        Url        @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@id([collectionId, urlId])
  @@index([urlId])
}

model SavedUrlReview {
  id         String   @id @default(cuid())
  ownerId   String
  urlId     Int
  reviewedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  url Url @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@unique([ownerId, urlId])
  @@index([urlId])
  @@index([ownerId, reviewedAt])
}

model OperationRun {
  id            String   @id @default(cuid())
  ownerId       String
  type          String
  status        String   @default("queued")
  total         Int      @default(0)
  completed     Int      @default(0)
  failed        Int      @default(0)
  progressPct   Int      @default(0)
  stage         String?
  statusMessage String?
  error         String?
  meta          Json?
  createdAt     DateTime @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  updatedAt     DateTime @updatedAt

  items OperationRunItem[]

  @@index([ownerId, updatedAt])
  @@index([type, status])
  @@index([status, updatedAt])
}

model OperationRunItem {
  id           String   @id @default(cuid())
  runId        String
  resourceType String
  resourceId   Int?
  resourceKey  String?
  status       String   @default("queued")
  error        String?
  result       Json?
  attemptCount Int      @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  run OperationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  @@index([runId, status])
  @@index([resourceType, resourceId])
  @@index([resourceType, resourceKey])
}

model StoredFile {
  id              String    @id @default(cuid())
  uploadSessionId String?   @unique
  fileName       String
  mimeType       String
  size           Int
  description    String?
  uploaderName   String
  uploaderId     String?
  tags           String[]  @default([])
  visibility     String    @default("private")
  downloads      Int       @default(0)
  favoritesCount Int       @default(0)
  isFavorited    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  storagePath    String // absolute path to file on disk
  folderId       String?
  folder         Folder?   @relation(fields: [folderId], references: [id])
  contentHash    String?

  captureType CaptureType @default(UPLOAD)
  captureScope CaptureScope @default(SOURCE_PAGE)
  sha256      String?
  sourceUrl   String?
  sourcePublishedAt DateTime?
  sourceAuthors     String[]  @default([])

  documentRevision    DocumentRevision?
  primaryForDocuments Document[]
  captureEvent        CaptureEvent?

  urlId Int?
  url   Url? @relation("UrlSnapshots", fields: [urlId], references: [id], onDelete: SetNull)

  discoveredDocumentId String?
  discoveredDocument   UrlDiscoveredDocument? @relation("DiscoveredDocumentFiles", fields: [discoveredDocumentId], references: [id], onDelete: SetNull)

  taggerVersion String?
  tagsMeta      Json?

  taggingStatus TaggingStatus @default(NONE)
  taggingJobId  String?
  taggingError  String?

  notebookSources NotebookSource[] @relation("FileNotebookSources")

  @@index([urlId])
  @@index([discoveredDocumentId])
  @@index([deletedAt])
  @@index([taggingStatus])
}

model UrlDiscoveryRun {
  id String @id @default(cuid())

  sourceUrlId Int
  sourceUrl   Url @relation("UrlDiscoveryRuns", fields: [sourceUrlId], references: [id], onDelete: Cascade)

  sourcePageUrl String
  query         String?
  status        String @default("RUNNING")
  errorCode     String?
  errorMessage  String?

  maxDepth       Int @default(1)
  candidateCount Int @default(0)
  verifiedCount  Int @default(0)
  capturedCount  Int @default(0)
  methodSummary  Json?

  startedAt   DateTime @default(now())
  completedAt DateTime?

  documents UrlDiscoveredDocument[]

  @@index([sourceUrlId, startedAt])
  @@index([status])
}

model UrlDiscoveredDocument {
  id String @id @default(cuid())

  sourceUrlId Int
  sourceUrl   Url @relation("UrlDiscoveredDocuments", fields: [sourceUrlId], references: [id], onDelete: Cascade)

  discoveryRunId String?
  discoveryRun   UrlDiscoveryRun? @relation(fields: [discoveryRunId], references: [id], onDelete: SetNull)

  url          String
  canonicalUrl String
  title        String
  anchorText   String?
  contextText  String?

  dateHint    DateTime?
  rawDateHint String?
  fileNameHint String?

  contentType   String?
  contentLength Int?
  verified      Boolean @default(false)

  score           Float @default(0)
  confidence      String @default("low")
  discoveryMethod String
  status          String @default("DISCOVERED")

  rawMeta Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  capturedAt  DateTime?
  captureError String?

  capturedFiles StoredFile[] @relation("DiscoveredDocumentFiles")

  @@unique([sourceUrlId, canonicalUrl])
  @@index([sourceUrlId, score])
  @@index([discoveryRunId])
  @@index([status])
}

model Folder {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?      @relation("FolderToFolder", fields: [parentId], references: [id])
  children  Folder[]     @relation("FolderToFolder")
  files     StoredFile[]
  createdAt DateTime     @default(now())
  deletedAt DateTime?

  @@index([deletedAt])
}

model Notebook {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources NotebookSource[]
  notes   Note[]
  chatRuns NotebookChatRun[]
}

model NotebookSource {
  id         String     @id @default(cuid())
  notebook   Notebook   @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  notebookId String
  kind       SourceKind

  url   Url? @relation("UrlNotebookSources", fields: [urlId], references: [id])
  urlId Int?

  file   StoredFile? @relation("FileNotebookSources", fields: [fileId], references: [id])
  fileId String?

  chunks       SourceChunk[]
  embeddingJob EmbeddingJob?
  pages        SourcePage[]
  ingestionJob IngestionJob?
  createdAt    DateTime      @default(now())

  activeRevisionId String?
  activeRevision   SourceRevision? @relation("ActiveRevision", fields: [activeRevisionId], references: [id])

  revisions SourceRevision[] @relation("SourceRevisions")

  @@unique([notebookId, urlId])
  @@unique([notebookId, fileId])
}

model SourceRevision {
  id String @id @default(cuid())

  source   NotebookSource @relation("SourceRevisions", fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId String

  activeForSources NotebookSource[] @relation("ActiveRevision")

  ordinal     Int
  contentHash String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  documentRevisionId String?
  documentRevision   DocumentRevision? @relation(fields: [documentRevisionId], references: [id], onDelete: SetNull)

  pipelineConfigId String?
  pipelineConfig   PipelineConfig? @relation(fields: [pipelineConfigId], references: [id], onDelete: SetNull)

  chunks SourceChunk[]
  pages  SourcePage[]

  extractionTraces ExtractionTrace[]

  @@unique([sourceId, ordinal])
  @@index([documentRevisionId])
  @@index([pipelineConfigId])
  @@index([sourceId, isActive])
}

model SourceChunk {
  id         String         @id @default(cuid())
  source     NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId   String
  revision   SourceRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String
  idx        Int
  text       String
  tokens     Int

  embedding      Unsupported("vector(1536)")?
  embeddingModel String?
  embeddedAt     DateTime?
  fts            Unsupported("tsvector")?     @default(dbgenerated())
  globalStart    Int?
  globalEnd      Int?

  pageStart Int?
  pageEnd   Int?
  charStart Int?
  charEnd   Int?

  createdAt DateTime @default(now())

  @@unique([revisionId, idx])
  @@index([sourceId, revisionId])
}

model EmbeddingJob {
  id       String         @id @default(cuid())
  source   NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId String         @unique

  status       TaggingStatus @default(PENDING)
  attemptCount Int           @default(0)
  error        String?
  queueJobId      String?
  stage           String?
  progressPct     Int       @default(0)
  statusMessage   String?
  startedAt       DateTime?
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?
  lastErrorAt     DateTime?
  meta            Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngestionJob {
  id       String         @id @default(cuid())
  source   NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId String         @unique

  status       TaggingStatus @default(PENDING)
  attemptCount Int           @default(0)
  error        String?
  queueJobId      String?
  stage           String?
  progressPct     Int       @default(0)
  statusMessage   String?
  startedAt       DateTime?
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?
  lastErrorAt     DateTime?
  meta            Json?
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
}

model SourcePage {
  id         String         @id @default(cuid())
  source     NotebookSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId   String
  pageNumber Int
  text       String

  // global offsets into the concatenated fullText (including page separators)
  globalStart Int
  globalEnd   Int

  createdAt DateTime @default(now())

  revision   SourceRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String

  @@unique([revisionId, pageNumber])
  @@index([sourceId, revisionId])
  @@index([sourceId])
}

model Note {
  id         String   @id @default(cuid())
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  notebookId String
  title      String?
  content    String
  citations  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NotebookChatRun {
  id         String   @id @default(cuid())
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  notebookId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  requestId String?

  promptVersion String
  answerMode    String
  model         String?
  status        NotebookChatRunStatus @default(STARTED)

  userMessage String
  history     Json?

  scopedSourceIds    String[] @default([])
  retrievedChunkIds  String[] @default([])
  finalChunkIds      String[] @default([])
  sourceRevisionIds  String[] @default([])
  documentRevisionIds String[] @default([])
  pipelineConfigIds  String[] @default([])

  openaiResponseId String?

  answer    String?
  citations Json?
  evidence  Json?
  suggested Json?

  groundingVersion       String?
  groundingStatus        String?
  supportedClaimsCount   Int?
  unsupportedClaimsCount Int?
  grounding              Json?

  claimLinksVersion String?
  claimLinks        Json?

  error     String?
  latencyMs Int?

  @@index([notebookId, createdAt])
  @@index([status, createdAt])
}

model Document {
  id        String       @id @default(cuid())
  kind      DocumentKind
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Canonical pointers (exactly one should be set depending on kind)
  urlId Int? @unique
  url   Url? @relation(fields: [urlId], references: [id], onDelete: SetNull)

  primaryFileId String?     @unique
  primaryFile   StoredFile? @relation(fields: [primaryFileId], references: [id], onDelete: Cascade)

  revisions DocumentRevision[]
  extractionTraces ExtractionTrace[]
}

model DocumentRevision {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Monotonic per-document revision number
  ordinal   Int
  createdAt DateTime @default(now())

  // This revision is always backed by a physical StoredFile snapshot/artifact
  storedFileId String     @unique
  storedFile   StoredFile @relation(fields: [storedFileId], references: [id], onDelete: Cascade)

  // Capture metadata mirrored from StoredFile for traceability
  captureType CaptureType
  contentHash String?

  sourceRevisions SourceRevision[]
  captureEvent    CaptureEvent?

  extractionTraces ExtractionTrace[]

  @@unique([documentId, ordinal])
  @@index([documentId])
}

model ExtractionTrace {
  id String @id @default(cuid())

  sourceDocumentId String
  sourceDocument   Document @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  documentRevisionId String?
  documentRevision   DocumentRevision? @relation(fields: [documentRevisionId], references: [id], onDelete: SetNull)

  sourceRevisionId String?
  sourceRevision   SourceRevision? @relation(fields: [sourceRevisionId], references: [id], onDelete: SetNull)

  pipelineConfigId String?
  pipelineConfig   PipelineConfig? @relation(fields: [pipelineConfigId], references: [id], onDelete: SetNull)

  chunkIds        String[] @default([])
  pageNumbers     Int[]    @default([])
  charStart       Int?
  charEnd         Int?
  evidenceText    String?
  evidenceLocator Json?

  confidence        Float?
  extractionModel   String?
  extractionVersion String?
  rawPayload        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agencies         Agency[]          @relation("AgencyOrigin")
  issues           GovernanceIssue[] @relation("IssueOrigin")
  mandates         Mandate[]
  claims           DocumentClaim[]
  events           DocumentEvent[]
  positions        ActorPosition[]
  gaps             GovernanceGap[]
  relations        DocumentRelation[]
  timelineEntries  IssueTimelineEntry[]
  evidenceClusters EvidenceCluster[]

  @@index([sourceDocumentId, createdAt])
  @@index([documentRevisionId])
  @@index([sourceRevisionId])
  @@index([pipelineConfigId])
}

model Agency {
  id           String @id @default(cuid())
  slug         String @unique
  name         String
  shortName    String?
  category     AgencyCategory?
  jurisdiction String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  originTraceId String?
  originTrace   ExtractionTrace? @relation("AgencyOrigin", fields: [originTraceId], references: [id], onDelete: SetNull)

  mandates           Mandate[]
  positions          ActorPosition[]
  primaryGapLinks    GovernanceGap[]       @relation("PrimaryGapAgency")
  secondaryGapLinks  GovernanceGap[]       @relation("SecondaryGapAgency")
  eventActors        DocumentEvent[]       @relation("EventActorAgency")
  outgoingRelations  DocumentRelation[]    @relation("RelationFromAgency")
  incomingRelations  DocumentRelation[]    @relation("RelationToAgency")
  issueLinks         GovernanceIssueAgency[]
  subjectClaims      DocumentClaim[]       @relation("ClaimSubjectAgency")
  timelineEntries    IssueTimelineEntry[]  @relation("TimelineActorAgency")

  @@index([name])
  @@index([category])
}

model GovernanceIssue {
  id        String @id @default(cuid())
  slug      String @unique
  title     String
  summary   String?
  kind      GovernanceIssueKind   @default(GOVERNANCE_ISSUE)
  status    GovernanceIssueStatus @default(OPEN)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  originTraceId String?
  originTrace   ExtractionTrace? @relation("IssueOrigin", fields: [originTraceId], references: [id], onDelete: SetNull)

  agencies         GovernanceIssueAgency[]
  mandates         Mandate[]
  claims           DocumentClaim[]
  events           DocumentEvent[]
  positions        ActorPosition[]
  gaps             GovernanceGap[]
  relations        DocumentRelation[]
  timelineEntries  IssueTimelineEntry[]
  evidenceClusters EvidenceCluster[]

  @@index([kind, status])
  @@index([title])
}

model GovernanceIssueAgency {
  issueId   String
  agencyId  String
  roleLabel String?
  createdAt DateTime @default(now())

  issue  GovernanceIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  agency Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@id([issueId, agencyId])
  @@index([agencyId])
}

model Mandate {
  id            String @id @default(cuid())
  agencyId      String
  issueId       String?
  traceId       String
  title         String
  description   String?
  mandateType   MandateType @default(OTHER)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agency Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  issue  GovernanceIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  trace  ExtractionTrace  @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([agencyId, mandateType])
  @@index([issueId])
  @@index([traceId])
}

model DocumentClaim {
  id              String @id @default(cuid())
  issueId         String?
  traceId         String
  claimText       String
  claimSummary    String?
  subjectAgencyId String?
  polarity        PositionPolarity @default(UNKNOWN)
  scopeText       String?
  normalizedKey   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  issue            GovernanceIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  trace            ExtractionTrace  @relation(fields: [traceId], references: [id], onDelete: Cascade)
  subjectAgency    Agency?          @relation("ClaimSubjectAgency", fields: [subjectAgencyId], references: [id], onDelete: SetNull)
  positions        ActorPosition[]
  outgoingRelations DocumentRelation[] @relation("FromClaim")
  incomingRelations DocumentRelation[] @relation("ToClaim")

  @@index([issueId])
  @@index([traceId])
  @@index([subjectAgencyId])
  @@index([normalizedKey])
}

model DocumentEvent {
  id                       String @id @default(cuid())
  issueId                  String?
  actorAgencyId            String?
  traceId                  String
  title                    String
  summary                  String?
  eventDate                DateTime?
  eventDateText            String?
  eventDatePrecision       EventDatePrecision @default(UNKNOWN)
  sortDate                 DateTime?
  sortDateEnd              DateTime?
  usedDocumentDateFallback Boolean @default(false)
  metadata                 Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  issue           GovernanceIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  actorAgency     Agency?          @relation("EventActorAgency", fields: [actorAgencyId], references: [id], onDelete: SetNull)
  trace           ExtractionTrace  @relation(fields: [traceId], references: [id], onDelete: Cascade)
  timelineEntries IssueTimelineEntry[]

  @@index([issueId, sortDate])
  @@index([actorAgencyId])
  @@index([traceId])
}

model ActorPosition {
  id                     String @id @default(cuid())
  issueId                String
  agencyId               String
  claimId                String?
  traceId                String
  stanceText             String
  stanceSummary          String?
  polarity               PositionPolarity @default(UNKNOWN)
  effectiveDate          DateTime?
  effectiveDateText      String?
  effectiveDatePrecision EventDatePrecision @default(UNKNOWN)
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  issue           GovernanceIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  agency          Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  claim           DocumentClaim?  @relation(fields: [claimId], references: [id], onDelete: SetNull)
  trace           ExtractionTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)
  timelineEntries IssueTimelineEntry[]

  @@index([issueId, agencyId])
  @@index([claimId])
  @@index([traceId])
}

model GovernanceGap {
  id                String @id @default(cuid())
  issueId           String?
  primaryAgencyId   String?
  secondaryAgencyId String?
  traceId           String
  gapType           GovernanceGapType @default(OTHER)
  summary           String
  severity          Float?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  issue           GovernanceIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  primaryAgency   Agency?          @relation("PrimaryGapAgency", fields: [primaryAgencyId], references: [id], onDelete: SetNull)
  secondaryAgency Agency?          @relation("SecondaryGapAgency", fields: [secondaryAgencyId], references: [id], onDelete: SetNull)
  trace           ExtractionTrace  @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([issueId, gapType])
  @@index([primaryAgencyId])
  @@index([secondaryAgencyId])
  @@index([traceId])
}

model DocumentRelation {
  id           String @id @default(cuid())
  issueId      String?
  fromClaimId  String?
  toClaimId    String?
  fromAgencyId String?
  toAgencyId   String?
  traceId      String
  relationType DocumentRelationType
  confidence   Float?
  rationale    String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  issue      GovernanceIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  fromClaim  DocumentClaim?   @relation("FromClaim", fields: [fromClaimId], references: [id], onDelete: SetNull)
  toClaim    DocumentClaim?   @relation("ToClaim", fields: [toClaimId], references: [id], onDelete: SetNull)
  fromAgency Agency?          @relation("RelationFromAgency", fields: [fromAgencyId], references: [id], onDelete: SetNull)
  toAgency   Agency?          @relation("RelationToAgency", fields: [toAgencyId], references: [id], onDelete: SetNull)
  trace      ExtractionTrace  @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([issueId, relationType])
  @@index([fromClaimId])
  @@index([toClaimId])
  @@index([fromAgencyId])
  @@index([toAgencyId])
  @@index([traceId])
}

model IssueTimelineEntry {
  id            String @id @default(cuid())
  issueId       String
  eventId       String?
  positionId    String?
  traceId       String
  label         String
  summary       String?
  sortDate      DateTime?
  sortDateEnd   DateTime?
  sortPrecision EventDatePrecision @default(UNKNOWN)
  actorAgencyId String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  issue       GovernanceIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  event       DocumentEvent?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  position    ActorPosition?  @relation(fields: [positionId], references: [id], onDelete: SetNull)
  actorAgency Agency?         @relation("TimelineActorAgency", fields: [actorAgencyId], references: [id], onDelete: SetNull)
  trace       ExtractionTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([issueId, sortDate])
  @@index([eventId])
  @@index([positionId])
  @@index([actorAgencyId])
  @@index([traceId])
}

model EvidenceCluster {
  id         String @id @default(cuid())
  issueId    String?
  traceId    String
  clusterKey String?
  title      String
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  issue GovernanceIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  trace ExtractionTrace  @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([traceId])
  @@index([clusterKey])
}

model PipelineConfig {
  id         String   @id @default(cuid())
  name       String
  version    String
  config     Json
  configHash String
  codeSha    String?
  createdAt  DateTime @default(now())

  captureEvents   CaptureEvent[]
  sourceRevisions SourceRevision[]

  extractionTraces ExtractionTrace[]

  @@unique([name, version, configHash])
  @@index([name])
}

model AuditLog {
  id String @id @default(cuid())

  action       String
  resourceType AuditResourceType
  resourceId   String?
  status       AuditLogStatus @default(INFO)

  actorId   String?
  actorName String?
  requestId String?

  metadata Json?
  createdAt DateTime @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([action, createdAt])
  @@index([requestId])
}

model CaptureEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // who initiated capture (v1: just what you have today)
  actorId   String?
  actorName String?

  // request-level trace
  requestId String?

  // pipeline reproducibility
  pipelineConfigId String
  pipelineConfig   PipelineConfig @relation(fields: [pipelineConfigId], references: [id], onDelete: Restrict)

  // what was captured
  captureType CaptureType
  sourceUrl   String?
  urlId       Int?
  url         Url?        @relation(fields: [urlId], references: [id], onDelete: SetNull)

  // physical artifact + canonical revision (both pinned)
  storedFileId String     @unique
  storedFile   StoredFile @relation(fields: [storedFileId], references: [id], onDelete: Cascade)

  documentRevisionId String           @unique
  documentRevision   DocumentRevision @relation(fields: [documentRevisionId], references: [id], onDelete: Cascade)

  @@index([urlId])
  @@index([createdAt])
}
model GovernanceAnswerSession {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  requestId String?
  title     String?
  question  String?

  anchorDocumentIds    Json?
  anchorUrlIds         Json?
  sourceScope          String   @default("all")
  requestedWorkflowMode String?
  resolvedWorkflowMode  String?
  selectedIssueId       String?
  selectedAgencyId      String?
  collectorPurposeId    String?
  collectorPurpose      CollectorPurpose? @relation(fields: [collectorPurposeId], references: [id], onDelete: SetNull)
  metadata              Json?

  runs GovernanceAnswerRun[]

  @@index([updatedAt])
  @@index([selectedIssueId])
  @@index([selectedAgencyId])
  @@index([collectorPurposeId])
}

model GovernanceAnswerRun {
  id        String   @id
  sessionId String
  session   GovernanceAnswerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  requestId String?

  status   String @default("STARTED")
  question String
  answer   String?

  citations          Json?
  evidence           Json?
  caveats            Json?
  openQuestions      Json?
  suggestedFollowUps Json?
  structuredAnswer   Json?

  model              String?
  assistModel        String?
  openaiResponseId   String?
  previousResponseId String?
  previousRunId      String?

  anchorDocumentIds     Json?
  anchorUrlIds          Json?
  sourceScope           String   @default("all")
  requestedWorkflowMode String?
  resolvedWorkflowMode  String?
  selectedIssueId       String?
  selectedAgencyId      String?
  collectorPurposeId    String?
  collectorPurpose      CollectorPurpose? @relation(fields: [collectorPurposeId], references: [id], onDelete: SetNull)

  candidateDocumentIds Json?
  finalEvidenceChunkIds Json?
  sourceRevisionIds    Json?
  documentRevisionIds  Json?
  pipelineConfigIds    Json?
  retrievalMetadata    Json?
  groundingStatus      String?
  validation           Json?

  error     String?
  latencyMs Int?

  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([openaiResponseId])
  @@index([collectorPurposeId])
}
